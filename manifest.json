{
  "manifest_version": 3,
  "name": "YouTube Archive Sync Controller",
  "version": "0.2.0",
  "description": "Extension-first YouTube archive multi-tab sync controller.",
  "minimum_chrome_version": "114",
  "permissions": ["tabs", "scripting", "storage", "windows"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/controller/index.html",
  "action": {
    "default_title": "Archive Sync Controller"
  }
}
